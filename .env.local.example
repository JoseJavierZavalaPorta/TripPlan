# ── Oracle DB ─────────────────────────────────────────────────────────────────
ORACLE_USER=your_db_user
ORACLE_PASSWORD=your_db_password
ORACLE_CONNECT_STRING=your_connect_string
ORACLE_WALLET_PASSWORD=your_wallet_password

# For Railway deploy: base64-encoded zip of the wallet folder
# cat wallet.zip | base64 -w 0 > wallet.b64
ORACLE_WALLET_BASE64=

# For local dev: leave blank, wallet/ folder is used automatically
ORACLE_WALLET_DIR=

# Optional: path to Oracle Instant Client libs (for Thick mode)
ORACLE_LIB_DIR=

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_nextauth_secret_here

# Base URL of this app
NEXTAUTH_URL=http://localhost:3001

# Optional: Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── OCI Generative AI ─────────────────────────────────────────────────────────
# OCI user OCID, fingerprint, tenancy
OCI_USER_OCID=ocid1.user.oc1..your_user_ocid
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_TENANCY_OCID=ocid1.tenancy.oc1..your_tenancy_ocid
OCI_REGION=us-chicago-1

# For local dev: place key.pem inside oci-keys/ folder (git-ignored)
# For Railway: base64-encode the key and set this env var
# cat oci-keys/key.pem | base64 -w 0
OCI_PRIVATE_KEY_B64=
